// 1. Discover the telemetry log file and label it
local.file_match "telemetry" {
  path_targets = [{"__path__" = "/app/data/telemetry_logs.json", "job" = "exo_rag_inference"}]
}

// 2. Read the JSON logs
loki.source.file "telemetry_logs" {
  targets    = local.file_match.telemetry.targets
  forward_to = [loki.write.loki_backend.receiver]
}

// 3. Ship to the local Loki container
loki.write "loki_backend" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}
